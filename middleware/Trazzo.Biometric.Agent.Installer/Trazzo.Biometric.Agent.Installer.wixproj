<Project Sdk="WixToolset.Sdk/4.0.6">
  <PropertyGroup>
    <OutputName>Trazzo.Biometric.Agent</OutputName>
    <OutputType>Package</OutputType>
    <InstallerPlatform>x64</InstallerPlatform>
    <Cultures>es-ES;en-US</Cultures>
    <SuppressValidation>true</SuppressValidation>
    <AgentProject>..\Trazzo.Biometric.Agent\Trazzo.Biometric.Agent.csproj</AgentProject>
    <AgentPublishDir>$(MSBuildThisFileDirectory)obj\publish</AgentPublishDir>
    <GeneratedWxs>$(MSBuildThisFileDirectory)obj\$(Configuration)\Product.Generated.wxs</GeneratedWxs>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="WixToolset.UI.wixext" Version="4.0.6" />
    <PackageReference Include="WixToolset.Util.wixext" Version="4.0.6" />
    <Compile Include="$(GeneratedWxs)" />
  </ItemGroup>

  <!-- Lee la version directamente del .csproj del agente para mantener un unico punto de verdad -->
  <Target Name="ReadAgentVersion" BeforeTargets="PublishAgentForMsi">
    <XmlPeek XmlInputPath="$(AgentProject)" Query="/Project/PropertyGroup/Version/text()">
      <Output TaskParameter="Result" ItemName="_AgentVersionItems" />
    </XmlPeek>
    <PropertyGroup>
      <ProductVersion Condition="'@(_AgentVersionItems)' != ''">@(_AgentVersionItems)</ProductVersion>
      <ProductVersion Condition="'$(ProductVersion)' == ''">1.0.0</ProductVersion>
      <DefineConstants>ProductVersion=$(ProductVersion)</DefineConstants>
    </PropertyGroup>
    <Message Text="MSI version: $(ProductVersion)" Importance="high" />
  </Target>

  <Target Name="PublishAgentForMsi" BeforeTargets="CoreCompile">
    <!-- En CI los binarios llegan como artefacto del job anterior; solo publica si aún no existen -->
    <Exec Command="dotnet publish &quot;$(AgentProject)&quot; -c $(Configuration) -r win-x64 -p:SelfContained=true -o &quot;$(AgentPublishDir)&quot;"
          Condition="!Exists('$(AgentPublishDir)\Trazzo.Biometric.Agent.exe')" />
    <Error
      Condition="!Exists('$(AgentPublishDir)\Native\x64\libzkfpcsharp.dll')"
      Text="libzkfpcsharp.dll no encontrada en $(AgentPublishDir)\Native\x64\. Copia la DLL oficial x64 en Trazzo.Biometric.Agent\Native\x64\ antes de compilar el MSI." />
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildThisFileDirectory)scripts\GenerateInstallerWxs.ps1&quot; -PublishDir &quot;$(AgentPublishDir)&quot; -OutputPath &quot;$(GeneratedWxs)&quot;" />
  </Target>
</Project>
