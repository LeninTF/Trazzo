# Perfil para desarrollo local ÚNICAMENTE.
# Copiar este archivo como application-local.properties y completar los valores.
# Activar con: -Dspring.profiles.active=local  (o SPRING_PROFILES_ACTIVE=local)
# NO usar en producción ni en staging.
# application-local.properties está en .gitignore — NUNCA commitear ese archivo.

# Clave AES-256 de desarrollo (32 bytes en Base64). Generar con:
#   openssl rand -base64 32
app.encryption.key=REPLACE_WITH_LOCAL_AES256_KEY_BASE64

# PostgreSQL local (usar con docker-compose.dev.yml)
spring.datasource.url=${DB_URL:jdbc:postgresql://localhost:5432/trazzo_dev_db}
spring.datasource.username=${DB_USER:trazzo_dev}
spring.datasource.password=${DB_PASSWORD:trazzo_dev_pass}
spring.datasource.driver-class-name=org.postgresql.Driver

# Provisioning local (misma BD para desarrollo)
trazzo.provisioning.admin-url=${PROVISIONING_ADMIN_URL:jdbc:postgresql://localhost:5432/postgres}
trazzo.provisioning.admin-username=${PROVISIONING_ADMIN_USER:trazzo_dev}
trazzo.provisioning.admin-password=${PROVISIONING_ADMIN_PASS:trazzo_dev_pass}
trazzo.provisioning.db-host=${PROVISIONING_DB_HOST:localhost}
trazzo.provisioning.db-port=${PROVISIONING_DB_PORT:5432}

# Admin seeder: only active with local profile + explicit opt-in
trazzo.seed.admin.enabled=true
trazzo.seed.admin.email=admin@trazzo.pe
trazzo.seed.admin.password=REPLACE_WITH_LOCAL_ADMIN_PASSWORD

# JWT: clave HMAC-256 en Base64 (mínimo 32 bytes). Generar con:
#   openssl rand -base64 32
app.jwt.secret=REPLACE_WITH_LOCAL_JWT_SECRET_BASE64
